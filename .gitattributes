# Normalize all text files to LF in the repository.
# Prevents spurious CRLF/LF "modified" diffs on Windows checkouts.
* text=auto eol=lf

# Keep Windows-native scripts as CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicit text types (LF).
*.md    text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.txt   text eol=lf

# Binary files — never touch line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.ico  binary
*.zip  binary
