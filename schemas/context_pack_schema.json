{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Context Pack Schema",
  "description": "Standard Context Pack contract for Blog-Writing-Skill.",
  "version": "2.1.0",
  "type": "object",
  "required": [
    "version",
    "generated_at",
    "topic",
    "audience",
    "industry_context",
    "key_claims",
    "extracted_tables",
    "glossary",
    "risk_notes",
    "research_summary",
    "file_summary"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Context Pack version."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Generation timestamp in ISO 8601 format."
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^wf_\\d{8}_\\d{6}$",
      "description": "Optional workflow id, formatted as wf_YYYYMMDD_HHMMSS."
    },
    "topic": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200,
      "description": "Main article topic."
    },
    "audience": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Target audience segments."
    },
    "industry_context": {
      "type": "object",
      "required": ["industry", "market_segment", "core_advantage"],
      "properties": {
        "industry": {
          "type": "string",
          "minLength": 1
        },
        "market_segment": {
          "type": "string",
          "minLength": 1
        },
        "core_advantage": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "key_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim", "source", "confidence"],
        "properties": {
          "claim": {
            "type": "string",
            "minLength": 10,
            "description": "A factual claim that may be used downstream."
          },
          "source": {
            "type": "object",
            "required": ["type", "reference"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["pdf", "excel", "word", "web", "research", "user_provided"]
              },
              "reference": {
                "type": "string",
                "minLength": 5,
                "description": "Traceable source reference, such as report.pdf:Page 12 or URL/title/date."
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "credibility": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "verified_by": {
                "type": "string"
              },
              "verified_at": {
                "type": "string",
                "format": "date-time"
              }
            },
            "additionalProperties": true
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "data": {
            "type": "object",
            "description": "Optional structured numeric data referenced by the claim."
          }
        },
        "additionalProperties": true
      }
    },
    "extracted_tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["table_id", "source", "columns", "data"],
        "properties": {
          "table_id": {
            "type": "string",
            "pattern": "^table_\\d+$"
          },
          "source": {
            "type": "string",
            "minLength": 5,
            "description": "Traceable file or web reference."
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "unit": {
                  "type": "string",
                  "description": "Required for numeric columns."
                },
                "type": {
                  "type": "string",
                  "enum": ["string", "number", "date", "boolean"],
                  "default": "string"
                }
              },
              "additionalProperties": true
            }
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "data_format": {
            "type": "string",
            "enum": ["array_of_objects"],
            "default": "array_of_objects"
          },
          "data_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "extracted_at": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "glossary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "definition"],
        "properties": {
          "term": {
            "type": "string",
            "minLength": 1
          },
          "definition": {
            "type": "string",
            "minLength": 1
          },
          "context": {
            "type": "string"
          },
          "translations": {
            "type": "object",
            "properties": {
              "en": {"type": "string"},
              "zh": {"type": "string"}
            }
          }
        },
        "additionalProperties": true
      }
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk_type", "description"],
        "properties": {
          "risk_type": {
            "type": "string",
            "enum": ["data_gap", "uncertainty", "conflict", "limitation"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "mitigation": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "research_summary": {
      "type": "object",
      "required": ["sources_count", "last_updated", "key_findings"],
      "properties": {
        "sources_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_updated": {
          "type": "string",
          "format": "date-time"
        },
        "key_findings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "file_summary": {
      "type": "object",
      "required": ["files_processed", "total_pages", "extraction_notes"],
      "properties": {
        "files_processed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "total_pages": {
          "type": "integer",
          "minimum": 0
        },
        "extraction_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "data_lineage": {
      "type": "object",
      "description": "Optional lineage map for extracted tables."
    },
    "metadata": {
      "type": "object",
      "properties": {
        "files_processed": {"type": "integer", "minimum": 0},
        "research_sources": {"type": "integer", "minimum": 0},
        "total_data_points": {"type": "integer", "minimum": 0},
        "processing_time_seconds": {"type": "number", "minimum": 0}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
