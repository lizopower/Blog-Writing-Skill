{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Context Pack Schema",
  "description": "Standard Context Pack contract for Blog-Writing-Skill.",
  "version": "2.3.0",
  "type": "object",
  "required": [
    "version",
    "generated_at",
    "topic",
    "audience",
    "industry_context",
    "key_claims",
    "extracted_tables",
    "glossary",
    "risk_notes",
    "research_summary",
    "file_summary"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Context Pack version."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Generation timestamp in ISO 8601 format."
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^wf_\\d{8}_\\d{6}$",
      "description": "Optional workflow id, formatted as wf_YYYYMMDD_HHMMSS."
    },
    "topic": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200,
      "description": "Main article topic."
    },
    "audience": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Target audience segments."
    },
    "industry_context": {
      "type": "object",
      "required": ["industry", "market_segment", "core_advantage"],
      "properties": {
        "industry": {
          "type": "string",
          "minLength": 1
        },
        "market_segment": {
          "type": "string",
          "minLength": 1
        },
        "core_advantage": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "style_exemplars": {
      "type": "array",
      "description": "Optional author-approved examples used for voice, structure, rhythm, and guardrails only. They are not factual sources.",
      "items": {
        "type": "object",
        "required": ["reference", "scope"],
        "properties": {
          "reference": {
            "type": "string",
            "minLength": 1,
            "description": "File path, URL, or artifact id for the exemplar."
          },
          "scope": {
            "type": "string",
            "enum": ["style_only"],
            "description": "Must be style_only; factual claims still require key_claims sources."
          },
          "what_to_emulate": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Voice, structure, pacing, framing, or formatting traits to emulate."
          },
          "what_to_avoid": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Author-specific guardrails or patterns not to repeat."
          }
        },
        "additionalProperties": false
      }
    },
    "core_offerings": {
      "type": "array",
      "description": "Optional source-backed product/service context for contextual, non-promotional mentions.",
      "items": {
        "type": "object",
        "required": ["name", "value_prop", "target_user", "source_ref"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "value_prop": {
            "type": "string",
            "minLength": 1
          },
          "target_user": {
            "type": "string",
            "minLength": 1
          },
          "when_to_mention": {
            "type": "string",
            "description": "Specific reader problem or article section where this offering is relevant."
          },
          "source_ref": {
            "type": "string",
            "minLength": 5,
            "description": "Traceable source for the offering, positioning, and value claim."
          }
        },
        "additionalProperties": false
      }
    },
    "author_experience_notes": {
      "type": "array",
      "description": "Optional user-provided experiences, edits, or stories that may support personalization. Do not invent these downstream.",
      "items": {
        "type": "object",
        "required": ["note", "source_ref"],
        "properties": {
          "note": {
            "type": "string",
            "minLength": 1
          },
          "source_ref": {
            "type": "string",
            "minLength": 5
          },
          "usable_as": {
            "type": "string",
            "enum": ["story_anchor", "expert_commentary", "guardrail", "preference"],
            "description": "How the writer may use this note."
          }
        },
        "additionalProperties": false
      }
    },
    "key_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim", "source", "confidence"],
        "properties": {
          "claim": {
            "type": "string",
            "minLength": 10,
            "description": "A factual claim that may be used downstream."
          },
          "source": {
            "type": "object",
            "required": ["type", "reference"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["pdf", "excel", "word", "web", "research", "user_provided"]
              },
              "reference": {
                "type": "string",
                "minLength": 5,
                "description": "Traceable source reference, such as report.pdf:Page 12 or URL/title/date."
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "credibility": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "verified_by": {
                "type": "string"
              },
              "verified_at": {
                "type": "string",
                "format": "date-time"
              }
            },
            "additionalProperties": true
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "data": {
            "type": "object",
            "description": "Optional structured numeric data referenced by the claim."
          }
        },
        "additionalProperties": true
      }
    },
    "extracted_tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["table_id", "source", "columns", "data"],
        "properties": {
          "table_id": {
            "type": "string",
            "pattern": "^table_\\d+$"
          },
          "source": {
            "type": "string",
            "minLength": 5,
            "description": "Traceable file or web reference."
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "unit": {
                  "type": "string",
                  "description": "Required for numeric columns."
                },
                "type": {
                  "type": "string",
                  "enum": ["string", "number", "date", "boolean"],
                  "default": "string"
                }
              },
              "additionalProperties": true
            }
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "data_format": {
            "type": "string",
            "enum": ["array_of_objects"],
            "default": "array_of_objects"
          },
          "data_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "extracted_at": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "glossary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "definition"],
        "properties": {
          "term": {
            "type": "string",
            "minLength": 1
          },
          "definition": {
            "type": "string",
            "minLength": 1
          },
          "context": {
            "type": "string"
          },
          "translations": {
            "type": "object",
            "properties": {
              "en": {"type": "string"},
              "zh": {"type": "string"}
            }
          }
        },
        "additionalProperties": true
      }
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk_type", "description"],
        "properties": {
          "risk_type": {
            "type": "string",
            "enum": ["data_gap", "uncertainty", "conflict", "limitation"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "mitigation": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "research_summary": {
      "type": "object",
      "required": ["sources_count", "last_updated", "key_findings"],
      "properties": {
        "sources_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_updated": {
          "type": "string",
          "format": "date-time"
        },
        "key_findings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "file_summary": {
      "type": "object",
      "required": ["files_processed", "total_pages", "extraction_notes"],
      "properties": {
        "files_processed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "total_pages": {
          "type": "integer",
          "minimum": 0
        },
        "extraction_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "seo_strategy": {
      "type": "object",
      "description": "Optional SEO strategy layer produced by seo-serp-strategist. English-first: all length thresholds, slug rules, and default locale target English markets. Backward compatible: packs without this object follow the non-SEO flow.",
      "required": ["target_keyword", "search_intent", "target_market", "serp_analysis"],
      "properties": {
        "target_keyword": {
          "type": "string",
          "minLength": 1,
          "description": "Primary English target keyword."
        },
        "secondary_keywords": {
          "type": "array",
          "items": {"type": "string"}
        },
        "search_intent": {
          "type": "string",
          "enum": ["informational", "commercial", "transactional", "navigational"],
          "description": "Primary search intent. B2B queries are often mixed; capture the rest in secondary_intents."
        },
        "secondary_intents": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["informational", "commercial", "transactional", "navigational"]
          }
        },
        "intent_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "buyer_stage": {
          "type": "string",
          "enum": ["awareness", "consideration", "decision"],
          "description": "Funnel position. Distinct from search_intent (query type); do not conflate."
        },
        "conversion_goal": {
          "type": "string",
          "description": "Connects the SEO brief to a sales/marketing goal."
        },
        "page_type": {
          "type": "string",
          "enum": ["guide", "comparison", "category", "landing", "faq", "case_study"]
        },
        "target_market": {
          "type": "object",
          "required": ["locale"],
          "description": "Structured target market. Required so cross-market (外贸) SEO never relies on a free-form string.",
          "properties": {
            "country": {"type": "string", "description": "ISO-3166 alpha-2, e.g. US."},
            "language": {"type": "string", "default": "en"},
            "locale": {"type": "string", "description": "Default English market such as en-US."}
          },
          "additionalProperties": true
        },
        "keyword_metrics": {
          "type": "object",
          "description": "Optional. Tavily does not guarantee these; allow manual fill.",
          "properties": {
            "search_volume": {"type": "integer", "minimum": 0},
            "difficulty": {"type": "number"},
            "cpc": {"type": "number"},
            "source": {"type": "string", "description": "tavily | manual | ahrefs | semrush ..."},
            "checked_at": {"type": "string", "format": "date-time"}
          },
          "additionalProperties": true
        },
        "serp_analysis": {
          "type": "object",
          "required": ["checked_at", "competitors"],
          "properties": {
            "checked_at": {"type": "string", "format": "date-time"},
            "device": {
              "type": "string",
              "enum": ["desktop", "mobile", "unknown"],
              "default": "desktop"
            },
            "serp_features": {
              "type": "array",
              "items": {"type": "string"}
            },
            "competitors": {
              "type": "array",
              "description": "Used only for intent/structure/gap analysis. NEVER a source of technical facts.",
              "items": {
                "type": "object",
                "required": ["rank", "url"],
                "properties": {
                  "rank": {"type": "integer", "minimum": 1},
                  "url": {"type": "string"},
                  "title": {"type": "string"},
                  "snippet": {"type": "string"},
                  "content_type": {"type": "string"},
                  "strengths": {"type": "array", "items": {"type": "string"}},
                  "weaknesses": {"type": "array", "items": {"type": "string"}}
                },
                "additionalProperties": true
              }
            },
            "paa_questions": {"type": "array", "items": {"type": "string"}},
            "related_queries": {"type": "array", "items": {"type": "string"}},
            "content_gaps": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": true
        },
        "serp_freshness_policy": {
          "type": "object",
          "description": "checked_at alone is not enough; define a staleness threshold.",
          "properties": {
            "max_age_days": {"type": "integer", "minimum": 1, "default": 90},
            "on_stale": {"type": "string", "enum": ["warn", "fail"], "default": "warn"}
          },
          "additionalProperties": true
        },
        "outline_constraints": {
          "type": "object",
          "properties": {
            "must_answer": {"type": "array", "items": {"type": "string"}},
            "must_include_entities": {"type": "array", "items": {"type": "string"}},
            "avoid_angles": {"type": "array", "items": {"type": "string"}},
            "differentiation_angle": {"type": "string"}
          },
          "additionalProperties": true
        },
        "on_page_recommendations": {
          "type": "object",
          "description": "Advisory SEO seeds from the strategist. NOT final values. Finalized into top-level seo_finalization by on-page-seo-finalizer.",
          "properties": {
            "meta_title": {"type": "string", "maxLength": 60},
            "meta_description": {"type": "string", "maxLength": 155},
            "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
            "image_alt_requirements": {"type": "array", "items": {"type": "string"}},
            "internal_link_targets": {"type": "array", "items": {"type": "object"}}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "seo_finalization": {
      "type": "object",
      "description": "Optional. Sole source of FINAL on-page values, written only by on-page-seo-finalizer. Physically separated from seo_strategy.on_page_recommendations (advisory).",
      "required": ["meta_title", "meta_description", "slug", "finalized_at"],
      "properties": {
        "meta_title": {"type": "string", "maxLength": 60},
        "meta_description": {"type": "string", "maxLength": 155},
        "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "image_alt": {"type": "array", "items": {"type": "object"}},
        "internal_links": {"type": "array", "items": {"type": "object"}},
        "overrides": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Which advisory values were adopted/overridden and why."
        },
        "finalized_at": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": true
    },
    "data_lineage": {
      "type": "object",
      "description": "Optional lineage map for extracted tables."
    },
    "metadata": {
      "type": "object",
      "properties": {
        "files_processed": {"type": "integer", "minimum": 0},
        "research_sources": {"type": "integer", "minimum": 0},
        "total_data_points": {"type": "integer", "minimum": 0},
        "processing_time_seconds": {"type": "number", "minimum": 0}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
